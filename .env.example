# The ID of your GitHub App
APP_ID=
WEBHOOK_SECRET=development

# Use `trace` to get verbose logging or `info` to show less
LOG_LEVEL=debug

# Go to https://smee.io/new set this to the URL that you are redirected to.
WEBHOOK_PROXY_URL=

# Bind to all network interfaces so the Railway load balancer can reach the app.
# Probot v14+ defaults to localhost (127.0.0.1); this overrides that behavior.
HOST=0.0.0.0
